# ─────────────────────────────────────────────────────────────────────────────
# Bolt Abacus — PRODUCTION environment template
#
# HOW TO USE:
#   1. Copy this file to ".env.production" (same folder):  cp .env.production.example .env.production
#   2. Fill in every <PLACEHOLDER>. Lines that already have a value are sensible defaults.
#   3. NEVER commit .env.production — it is gitignored. This .example file IS committed (no secrets).
#   4. The real .env.production lives on the SERVER (the EC2 box), copied there at deploy time.
#
# Anything wrapped in <...> must be replaced. Blank values are intentional (optional / unset).
# ─────────────────────────────────────────────────────────────────────────────

# ─── Django core ──────────────────────────────────────────────────────────────
# Generate once with:  python -c "import secrets; print(secrets.token_hex(50))"
DJANGO_SECRET_KEY=<GENERATE_A_LONG_RANDOM_STRING>
DJANGO_SETTINGS_MODULE=config.settings.production
# Comma-separated hostnames the API answers on (no protocol, no slash).
DJANGO_ALLOWED_HOSTS=api.boltabacus.com

# ─── Database (RDS Postgres) ────────────────────────────────────────────────────
# From Track B1. Format: postgres://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=postgres://bolt:<DB_PASSWORD>@<RDS_ENDPOINT>:5432/bolt_prod
# Read replica — leave BLANK until a replica is provisioned (Wave 3).
REPLICA_DATABASE_URL=

# ─── Redis (ElastiCache) ────────────────────────────────────────────────────────
# From Track B2. Format: redis://:AUTH_TOKEN@HOST:6379/0  (or redis://HOST:6379/0 if no auth)
REDIS_URL=redis://<ELASTICACHE_ENDPOINT>:6379/0
REDIS_MAX_CONNECTIONS=50

# ─── CORS / cookies ─────────────────────────────────────────────────────────────
# The frontend origin(s) allowed to call the API. Comma-separated, include https://.
CORS_ALLOWED_ORIGINS=https://app.boltabacus.com
# Leading dot lets the refresh cookie work across api.* and app.* subdomains.
REFRESH_COOKIE_DOMAIN=.boltabacus.com
REFRESH_COOKIE_NAME=refresh_token

# ─── JWT lifetimes ──────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── AWS S3 (media + static buckets) ────────────────────────────────────────────
# Bucket names are ALWAYS required (from Track B3).
AWS_STORAGE_BUCKET_NAME=bolt-abacus-media-prod
AWS_STATIC_BUCKET_NAME=bolt-abacus-static-prod
AWS_S3_REGION_NAME=ap-south-1
#
# Access keys — TWO options. Pick ONE:
#   Option A (recommended on EC2): attach an IAM ROLE to the instance and LEAVE THESE BLANK.
#                                  boto3 picks up temporary credentials automatically.
#   Option B (outside AWS / quick start): paste a dedicated S3-only IAM user's key here.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional: override the static URL if you put CloudFront in front of the bucket.
# STATIC_URL=https://<cloudfront-domain>/static/

# ─── Sentry (error tracking — optional) ─────────────────────────────────────────
# Leave blank to disable. Get the DSN from your Sentry project settings.
SENTRY_DSN=

# ─── Email (SendGrid SMTP) ──────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=<SENDGRID_API_KEY>
DEFAULT_FROM_EMAIL=no-reply@boltabacus.com

# ─── Container image (read by docker-compose.prod.yml / deploy.sh) ───────────────
# For ECR set IMAGE_NAME to the full repo URI; otherwise the default below is used.
# IMAGE_NAME=<account-id>.dkr.ecr.ap-south-1.amazonaws.com/bolt-abacus-api
# IMAGE_TAG=latest
